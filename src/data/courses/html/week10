### Destructuring

\`\`\`js
// Array destructuring
const [first, second, ...rest] = [1, 2, 3, 4, 5];
// first=1, second=2, rest=[3,4,5]

// Object destructuring
const { name, age, city = 'Mumbai' } = user;
// city default value hai agar user.city undefined ho

// Function parameter destructuring
function greet({ name, age }) {
  return \`Hello \${name}, tum \${age} saal ke ho!\`;
}

// Nested destructuring
const { address: { city, pincode } } = user;

// Rename while destructuring
const { name: userName, email: userEmail } = user;
\`\`\`

### Spread aur Rest

\`\`\`js
// Spread — expand karo
const arr1 = [1, 2, 3];
const arr2 = [...arr1, 4, 5, 6]; // [1,2,3,4,5,6]

const obj1 = { a: 1, b: 2 };
const obj2 = { ...obj1, c: 3 }; // { a:1, b:2, c:3 }

// Array copy
const copy = [...original];

// Object merge
const merged = { ...defaults, ...overrides };

// Function call
Math.max(...arr1);  // Math.max(1, 2, 3)

// Rest in functions
function sum(...nums) {
  return nums.reduce((a, b) => a + b, 0);
}
\`\`\`

### Array Methods

\`\`\`js
const users = [
  { name: 'Rahul', age: 21, score: 85 },
  { name: 'Priya', age: 19, score: 92 },
  { name: 'Arjun', age: 23, score: 78 },
];

// find — first match
const rahul = users.find(u => u.name === 'Rahul');

// findIndex
const idx = users.findIndex(u => u.name === 'Arjun');

// some — koi ek match karta hai?
const hasTopScorer = users.some(u => u.score >= 90);

// every — sab match karte hain?
const allAdults = users.every(u => u.age >= 18);

// sort
const sorted = [...users].sort((a, b) => b.score - a.score); // descending

// flat aur flatMap
const nested = [[1,2], [3,4], [5,6]];
nested.flat(); // [1,2,3,4,5,6]

// Object.entries, Object.keys, Object.values
Object.keys(obj);    // ['key1', 'key2']
Object.values(obj);  // ['val1', 'val2']
Object.entries(obj); // [['key1','val1'],['key2','val2']]
\`\`\`

