### Fetch with Loading State

\`\`\`js
async function loadUsers() {
  const container = document.getElementById('users');

  // Loading state dikhao
  container.innerHTML = '<div class="loading">Loading... ⏳</div>';

  try {
    const res  = await fetch('https://jsonplaceholder.typicode.com/users');
    const data = await res.json();

    // Data render karo
    container.innerHTML = data.map(user => \`
      <div class="card">
        <h3>\${user.name}</h3>
        <p>📧 \${user.email}</p>
        <p>🌐 \${user.website}</p>
      </div>
    \`).join('');

  } catch (error) {
    container.innerHTML = \`<div class="error">❌ Data load nahi hua: \${error.message}</div>\`;
  }
}
\`\`\`

### POST Request (Data Bhejno)

\`\`\`js
async function createPost(title, body) {
  try {
    const res = await fetch('https://jsonplaceholder.typicode.com/posts', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title, body, userId: 1 })
    });

    const data = await res.json();
    console.log('Created:', data);  // { id: 101, title: ..., body: ... }
    return data;
  } catch (error) {
    console.error('Error:', error);
  }
}
\`\`\`

### Promise.all — Multiple APIs Ek Saath

\`\`\`js
async function loadDashboard() {
  const [users, posts, todos] = await Promise.all([
    fetch('https://jsonplaceholder.typicode.com/users').then(r => r.json()),
    fetch('https://jsonplaceholder.typicode.com/posts').then(r => r.json()),
    fetch('https://jsonplaceholder.typicode.com/todos').then(r => r.json()),
  ]);

  console.log(users.length, posts.length, todos.length);
}
\`\`\``,
